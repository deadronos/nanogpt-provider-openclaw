{
  "name": "@deadronos/nanogpt-provider-openclaw",
  "version": "0.1.1",
  "description": "OpenClaw NanoGPT provider plugin",
  "type": "module",
  "keywords": [
    "openclaw",
    "plugin",
    "provider",
    "nanogpt",
    "llm"
  ],
  "homepage": "https://github.com/deadronos/nanogpt-provider-openclaw#readme",
  "bugs": {
    "url": "https://github.com/deadronos/nanogpt-provider-openclaw/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deadronos/nanogpt-provider-openclaw.git"
  },
  "license": "MIT",
  "files": [
    "index.ts",
    "api.ts",
    "models.ts",
    "runtime.ts",
    "runtime/config.ts",
    "runtime/dynamic-models.ts",
    "runtime/discovery.ts",
    "runtime/provider-pricing.ts",
    "runtime/routing.ts",
    "runtime/subscription.ts",
    "runtime/usage.ts",
    "catalog/models-json-snapshot.ts",
    "catalog/build-provider.ts",
    "provider/auth.ts",
    "provider/catalog-hooks.ts",
    "provider/anomaly-types.ts",
    "provider/anomaly-logger.ts",
    "provider/nanogpt-logger.ts",
    "provider/inspection.ts",
    "provider/markers.ts",
    "provider/replay-hooks.ts",
    "provider/replay/types.ts",
    "provider/replay/inspection.ts",
    "provider/replay/warnings.ts",
    "provider/replay/sanitize.ts",
    "provider/replay/validate.ts",
    "provider/tool-schema-hooks.ts",
    "provider/error-hooks.ts",
    "provider/stream-hooks.ts",
    "provider/stream/types.ts",
    "provider/stream/inspection.ts",
    "provider/stream/payload.ts",
    "provider/stream/bridge.ts",
    "provider/stream/replay.ts",
    "provider/stream/warnings.ts",
    "provider/bridge/types.ts",
    "provider/bridge/system-prompt.ts",
    "provider/bridge/object-parser.ts",
    "provider/bridge/xml-parser.ts",
    "provider/bridge/retry.ts",
    "provider/bridge/keepalive.ts",
    "provider-catalog.ts",
    "provider-discovery.ts",
    "nanogpt-errors.ts",
    "web-search/credentials.ts",
    "web-search/results.ts",
    "image/request.ts",
    "image/response.ts",
    "image-generation-provider.ts",
    "web-search.ts",
    "onboard.ts",
    "shared/guards.ts",
    "shared/parse.ts",
    "shared/http.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && node ./scripts/stage-package-dir.mjs",
    "build:tgz": "npm run build && npm pack ./dist/package --pack-destination ./dist",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check --threads=1",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:all": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --fix && npm run format"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.22"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "openclaw": "2026.4.22",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "oxfmt": "0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1"
  },
  "overrides": {
    "axios": "1.15.0",
    "hono": "4.12.14",
    "protobufjs": "7.5.5",
    "tar": "7.5.13",
    "fast-xml-parser": "5.7.0",
    "uuid": "14.0.0"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.15.0",
      "hono": "4.12.14",
      "protobufjs": "7.5.5",
      "tar": "7.5.13",
      "fast-xml-parser": "5.7.0",
      "uuid": "14.0.0"
    },
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "@matrix-org/matrix-sdk-crypto-nodejs",
      "@whiskeysockets/baileys",
      "esbuild",
      "koffi",
      "openclaw",
      "protobufjs",
      "sharp"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "providers": [
      "nanogpt"
    ],
    "compat": {
      "pluginApi": ">=2026.4.22",
      "minGatewayVersion": "2026.4.22"
    },
    "build": {
      "openclawVersion": "2026.4.22",
      "pluginSdkVersion": "2026.4.22"
    }
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.69.0"
  }
}
