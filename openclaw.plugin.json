{
  "id": "nanogpt",
  "name": "NanoGPT",
  "description": "NanoGPT provider plugin for OpenClaw",
  "providerDiscoveryEntry": "./provider-discovery.ts",
  "providers": [
    "nanogpt"
  ],
  "webSearchProviders": [
    "nanogpt"
  ],
  "providerAuthEnvVars": {
    "nanogpt": [
      "NANOGPT_API_KEY"
    ]
  },
  "setup": {
    "providers": [
      {
        "id": "nanogpt",
        "envVars": [
          "NANOGPT_API_KEY"
        ]
      }
    ]
  },
  "providerAuthChoices": [
    {
      "provider": "nanogpt",
      "method": "api-key",
      "choiceId": "nanogpt-api-key",
      "choiceLabel": "NanoGPT API key",
      "groupId": "nanogpt",
      "groupLabel": "NanoGPT",
      "groupHint": "Subscription or pay-as-you-go",
      "optionKey": "nanogptApiKey",
      "cliFlag": "--nanogpt-api-key",
      "cliOption": "--nanogpt-api-key <key>",
      "cliDescription": "NanoGPT API key"
    }
  ],
  "uiHints": {
    "routingMode": {
      "label": "Routing Mode",
      "help": "Choose auto, subscription, or paygo routing."
    },
    "catalogSource": {
      "label": "Catalog Source",
      "help": "Choose how NanoGPT model discovery should work."
    },
    "requestApi": {
      "label": "Request API",
      "help": "Choose OpenAI chat completions or OpenAI responses transport."
    },
    "provider": {
      "label": "Provider Override",
      "help": "Optional NanoGPT upstream provider id for paygo provider selection."
    },
    "bridgeMode": {
      "label": "Bridge Mode",
      "help": "Enable the NanoProxy-style bridge for tool-enabled completions requests."
    },
    "bridgeProtocol": {
      "label": "Bridge Protocol",
      "help": "Choose the structured bridge protocol to request from NanoGPT."
    },
    "responseFormat": {
      "label": "Response Format",
      "help": "Optionally inject OpenAI-compatible response_format into NanoGPT requests."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "routingMode": {
        "type": "string",
        "enum": [
          "auto",
          "subscription",
          "paygo"
        ]
      },
      "catalogSource": {
        "type": "string",
        "enum": [
          "auto",
          "canonical",
          "subscription",
          "paid",
          "personalized"
        ]
      },
      "requestApi": {
        "type": "string",
        "enum": [
          "auto",
          "completions",
          "responses"
        ]
      },
        "provider": {
          "type": "string"
        },
        "bridgeMode": {
          "type": "string",
          "enum": [
            "never",
            "always"
          ]
        },
        "bridgeProtocol": {
          "type": "string",
          "enum": [
            "object",
            "xml"
          ]
        },
        "responseFormat": {
          "anyOf": [
            {
              "const": false
            },
            {
              "type": "string",
              "enum": [
                "json_object"
              ]
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type"
              ],
              "properties": {
                "type": {
                  "const": "json_schema"
                },
                "schema": {
                  "type": "object"
                }
              }
            }
          ]
        },
        "webSearch": {
          "type": "object",
        "properties": {
          "apiKey": {
            "type": "string"
          }
        }
      }
    }
  },
  "contracts": {
    "imageGenerationProviders": [
      "nanogpt"
    ],
    "webSearchProviders": [
      "nanogpt"
    ]
  }
}
